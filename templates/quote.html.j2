<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<title>Quotation {{ q.quote_number }} — {{ seller.name_en }}</title>
<style>
  :root { --ink:#1a1d24; --muted:#6b7280; --line:#e5e7eb; --accent:#0f4c81; --soft:#f4f6f9; }
  * { box-sizing: border-box; }
  body { font-family: "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
         color: var(--ink); margin: 0; background:#fff; line-height: 1.55; }
  .page { max-width: 820px; margin: 0 auto; padding: 48px 56px; }
  header { display:flex; justify-content:space-between; align-items:flex-start;
           border-bottom: 3px solid var(--accent); padding-bottom: 18px; }
  .brand h1 { margin:0; font-size: 22px; letter-spacing:.5px; color: var(--accent); }
  .brand p { margin:2px 0 0; color: var(--muted); font-size: 12px; }
  .meta { text-align:right; font-size: 13px; }
  .meta .qno { font-size: 16px; font-weight: 700; }
  h2.doc-title { text-align:center; margin: 26px 0 4px; font-size: 19px; }
  h2.doc-title small { display:block; font-weight: 400; color: var(--muted); font-size: 13px; }
  .parties { display:flex; gap: 24px; margin: 22px 0; font-size: 13px; }
  .party { flex:1; background: var(--soft); border-radius: 8px; padding: 12px 16px; }
  .party .label { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); }
  .letters { font-size: 13.5px; margin: 18px 0; }
  .letters .zh { margin-bottom: 12px; white-space: pre-wrap; }
  .letters .en { color:#374151; white-space: pre-wrap; }
  table.items { width:100%; border-collapse: collapse; font-size: 13px; margin: 16px 0; }
  table.items th { background: var(--accent); color:#fff; padding: 8px 10px; text-align:left; font-weight:600; }
  table.items td { padding: 8px 10px; border-bottom: 1px solid var(--line); vertical-align: top; }
  table.items td.num, table.items th.num { text-align: right; white-space: nowrap; }
  .zh-name { color: var(--muted); font-size: 12px; }
  .totals { margin-left:auto; width: 340px; font-size: 13.5px; }
  .totals div { display:flex; justify-content:space-between; padding: 4px 10px; }
  .totals .grand { border-top: 2px solid var(--ink); font-weight: 700; font-size: 15px; padding-top: 8px; }
  .totals .cny { color: var(--accent); }
  .fx-note { text-align:right; font-size: 11px; color: var(--muted); margin-top: 2px; }
  section.block { margin-top: 20px; font-size: 12.5px; }
  section.block h3 { font-size: 13px; margin: 0 0 6px; color: var(--accent); }
  section.block p { margin: 4px 0; }
  section.block .en { color:#4b5563; }
  .answers { background: var(--soft); border-left: 3px solid var(--accent);
             padding: 10px 14px; border-radius: 0 8px 8px 0; white-space: pre-wrap; }
  footer { margin-top: 34px; padding-top: 12px; border-top: 1px solid var(--line);
           font-size: 11px; color: var(--muted); display:flex; justify-content:space-between; }
  @media print { .page { padding: 24px 28px; } }
</style>
</head>
<body>
<div class="page">
  <header>
    <div class="brand">
      <h1>{{ seller.name_en }}</h1>
      <p>{{ seller.jurisdiction_en }} · {{ seller.website }} · {{ seller.email }}</p>
    </div>
    <div class="meta">
      <div class="qno">{{ q.quote_number }}</div>
      <div>Issue date / 报价日期: {{ q.issue_date.isoformat() }}</div>
      <div>Valid until / 有效期至: <strong>{{ q.valid_until.isoformat() }}</strong></div>
    </div>
  </header>

  <h2 class="doc-title">报 价 单<small>QUOTATION</small></h2>

  <div class="parties">
    <div class="party">
      <div class="label">To / 致</div>
      <div><strong>{{ q.customer.company }}</strong></div>
      <div>{{ q.customer.contact_name }} · {{ q.customer.email }}</div>
    </div>
    <div class="party">
      <div class="label">From / 供应方</div>
      <div><strong>{{ seller.name_zh }}</strong></div>
      <div>{{ seller.jurisdiction_zh }}</div>
    </div>
  </div>

  <div class="letters">
    <div class="zh">{{ q.cover.cover_letter_zh }}</div>
    <div class="en">{{ q.cover.cover_letter_en }}</div>
  </div>

  <table class="items">
    <thead>
      <tr>
        <th>SKU</th><th>Item / 项目</th><th class="num">Qty / 数量</th>
        <th class="num">Unit Price (USD)<br>单价(美元)</th>
        <th class="num">Discount<br>折扣</th>
        <th class="num">Amount (USD)<br>金额(美元)</th>
        <th class="num">≈ Amount (CNY)<br>约合(人民币)</th>
      </tr>
    </thead>
    <tbody>
      {% for l in q.lines %}
      <tr>
        <td>{{ l.sku }}</td>
        <td>{{ l.name_en }}<div class="zh-name">{{ l.name_zh }} · {{ l.unit_zh }}</div></td>
        <td class="num">{{ l.quantity }} {{ l.unit }}</td>
        <td class="num">{{ "{:,.2f}".format(l.unit_price_usd) }}</td>
        <td class="num">{% if l.discount_pct %}-{{ l.discount_pct }}%{% else %}—{% endif %}</td>
        <td class="num">{{ "{:,.2f}".format(l.line_total_usd) }}</td>
        <td class="num">{{ "{:,.2f}".format(l.line_total_cny) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <div class="totals">
    <div><span>Subtotal / 小计 (USD)</span><span>{{ "{:,.2f}".format(q.subtotal_usd) }}</span></div>
    <div><span>Discount / 折扣 (USD)</span><span>-{{ "{:,.2f}".format(q.discount_usd) }}</span></div>
    <div class="grand"><span>TOTAL / 合计 (USD)</span><span>{{ "{:,.2f}".format(q.total_usd) }}</span></div>
    <div class="grand cny"><span>≈ 合计 (CNY)</span><span>{{ "{:,.2f}".format(q.total_cny) }}</span></div>
  </div>
  <div class="fx-note">
    USD/CNY {{ q.fx.rate }} · {{ q.fx.source }} · {{ q.fx.as_of }}
    {% if q.fx.offline %}· 参考汇率,以付款日实际汇率为准 / indicative only{% endif %}
    {% if not q.fx.offline %}· 人民币金额仅供参考 / CNY amounts are indicative{% endif %}
  </div>

  {% if q.cover.answers_zh or q.cover.answers_en %}
  <section class="block">
    <h3>您的问题答复 / Answers to Your Questions</h3>
    <div class="answers">{{ q.cover.answers_zh }}{% if q.cover.answers_zh and q.cover.answers_en %}

{% endif %}{{ q.cover.answers_en }}</div>
  </section>
  {% endif %}

  <section class="block">
    <h3>付款条款 / Payment Terms</h3>
    <p>{{ q.payment_terms_zh }}</p>
    <p class="en">{{ q.payment_terms_en }}</p>
    {% for note in q.extra_notes_zh %}<p>{{ note }}</p>{% endfor %}
    {% for note in q.extra_notes_en %}<p class="en">{{ note }}</p>{% endfor %}
  </section>

  <section class="block">
    <h3>法律条款 / Legal</h3>
    <p>{{ q.legal_zh }}</p>
    <p class="en">{{ q.legal_en }}</p>
  </section>

  <footer>
    <span>Generated by QuotePilot · powered by Qwen on Alibaba Cloud</span>
    <span>{{ q.quote_number }} · Page 1/1</span>
  </footer>
</div>
</body>
</html>
